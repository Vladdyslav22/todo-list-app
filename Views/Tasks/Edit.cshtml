@model ToDoListApp.Models.TaskItem
@using ToDoListApp.Models

@{
    ViewData["Title"] = "Edit";
}

<h2 class="mb-4">✏️ Edytuj zadanie</h2>

<div class="row">
    <div class="card p-4 shadow-sm">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Title" class="control-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-check mb-2">
                <input class="form-check-input" asp-for="IsDone" />
                <label class="form-check-label" asp-for="IsDone">Wykonane</label>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="💾 Zapisz zmiany" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">🔙 Powrót do listy</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
