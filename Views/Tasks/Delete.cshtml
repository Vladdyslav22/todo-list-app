@model ToDoListApp.Models.TaskItem

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div class="card p-4 shadow-sm">
    <h4 class="card-title">@Model.Title</h4>
    <p class="card-text">
        <strong>Status:</strong> @(Model.IsDone ? "✔️ Wykonane" : "❌ Nie") <br />
    </p>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2 mt-3">
            <input type="submit" value="🗑️ Usuń zadanie" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-outline-secondary">🔙 Powrót do listy</a>
        </div>
    </form>
</div>
