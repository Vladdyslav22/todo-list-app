<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web_Application</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web_Application.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="bg-dark text-white p-3 mb-4">
        <div class="container">
            <h1 class="h3">📝 ToDoListApp</h1>
        </div>
    </header>

    <main role="main" class="container mb-5">
        @RenderBody()
    </main>

    <footer class="bg-light text-center text-muted py-3">
        <small>© 2025 ToDoListApp</small>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>
